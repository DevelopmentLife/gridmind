# GridMind Staging Environment — Example tfvars
# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

aws_region = "us-east-1"

vpc_cidr           = "10.20.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]
private_subnets    = ["10.20.1.0/24", "10.20.2.0/24", "10.20.3.0/24"]
public_subnets     = ["10.20.101.0/24", "10.20.102.0/24", "10.20.103.0/24"]

route53_zone_id   = "Z0123456789EXAMPLE"
root_domain       = "gridmind.io"
access_log_bucket = "gridmind-alb-logs-staging"

alert_emails = ["oncall@gridmind.io", "dev@gridmind.io"]

# Set via env var: TF_VAR_grafana_admin_password
grafana_admin_password = ""

github_org  = "assertive-mind"
github_repo = "gridmind"
