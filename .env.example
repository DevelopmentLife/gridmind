# =============================================================================
# GridMind — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# All variables use the GRIDMIND_ prefix convention.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Environment: development | staging | production
GRIDMIND_ENV=development

# Log level: debug | info | warning | error
GRIDMIND_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Database host (use "postgres" for Docker Compose, "localhost" for bare metal)
GRIDMIND_DB_HOST=postgres

# Database port
GRIDMIND_DB_PORT=5432

# Database name
GRIDMIND_DB_NAME=gridmind

# Database user
GRIDMIND_DB_USER=gridmind

# Database password (change in staging/production)
GRIDMIND_DB_PASSWORD=gridmind_dev

# Full connection string (alternative to individual params)
# GRIDMIND_DATABASE_URL=postgresql://gridmind:gridmind_dev@postgres:5432/gridmind

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection URL
GRIDMIND_REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# NATS JetStream
# -----------------------------------------------------------------------------

# NATS server URL
GRIDMIND_NATS_URL=nats://nats:4222

# -----------------------------------------------------------------------------
# HashiCorp Vault
# -----------------------------------------------------------------------------

# Vault server address
GRIDMIND_VAULT_ADDR=http://vault:8200

# Vault access token (dev mode only — production uses Kubernetes auth)
GRIDMIND_VAULT_TOKEN=dev-root-token

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------

# JWT signing secret (RS256 key path in production)
GRIDMIND_JWT_SECRET=dev-jwt-secret-do-not-use-in-production

# Allowed CORS origins (comma-separated)
GRIDMIND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -----------------------------------------------------------------------------
# Anthropic API (AI Agent Runtime)
# -----------------------------------------------------------------------------

# Anthropic API key for Claude models
# In local dev, use a mock key — the cortex service stubs LLM calls
GRIDMIND_ANTHROPIC_API_KEY=sk-ant-mock-key-for-local-dev

# Default model for agent operations
GRIDMIND_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Max tokens per LLM request
GRIDMIND_ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Stripe (Billing & Payments)
# -----------------------------------------------------------------------------

# Stripe secret key (server-side)
GRIDMIND_STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe publishable key (client-side, exposed to browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Stripe webhook signing secret
GRIDMIND_STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# -----------------------------------------------------------------------------
# Resend (Email)
# -----------------------------------------------------------------------------

# Resend API key for transactional emails
GRIDMIND_RESEND_API_KEY=re_test_placeholder

# From address for outgoing emails
GRIDMIND_EMAIL_FROM=noreply@gridmind.io

# -----------------------------------------------------------------------------
# Cortex (Agent Runtime)
# -----------------------------------------------------------------------------

# Port for cortex gRPC/HTTP health endpoint
GRIDMIND_CORTEX_PORT=9090

# Agent heartbeat interval in seconds
GRIDMIND_AGENT_HEARTBEAT_INTERVAL=30

# Max retries for agent task execution
GRIDMIND_AGENT_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------

# Gateway HTTP port
GRIDMIND_GATEWAY_PORT=8000

# Rate limit: requests per minute per user
GRIDMIND_RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Frontend Services
# -----------------------------------------------------------------------------

# API URL exposed to browser (Next.js public env vars)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL exposed to browser
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Container Registry (CI/CD only)
# -----------------------------------------------------------------------------

# AWS ECR registry URL
# GRIDMIND_ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com

# Image tag (set by CI)
# GRIDMIND_IMAGE_TAG=sha-abc1234

# -----------------------------------------------------------------------------
# Observability (production only)
# -----------------------------------------------------------------------------

# Prometheus metrics port
# GRIDMIND_METRICS_PORT=9100

# Sentry DSN for error tracking
# GRIDMIND_SENTRY_DSN=

# Slack webhook for deploy notifications
# GRIDMIND_SLACK_WEBHOOK_URL=
